# Conexion SQL Server EPS (usuario read-only)
EPS_SERVER=192.168.4.5
EPS_DATABASE=EPS
EPS_USER=audit_agent
EPS_PASSWORD=changeme
EPS_DRIVER=ODBC Driver 17 for SQL Server
EPS_TIMEOUT=120

# Configuracion del dominio
ALMACEN_WIP_PROCESO_ID=16
ALMACEN_WIP_PROCESO_NOMBRE=Almacen WIP

# Aplicacion
LOG_LEVEL=INFO
DEV=false                    # habilita CORS para dev (frontend en :5173)
